---
import DemoBanner from "@/components/DemoBanner.astro"
import { AlertsFeed } from "@/components/islands/AlertsFeed"
import { MonitorButton } from "@/components/islands/MonitorButton"
import { PerceptionChart } from "@/components/islands/PerceptionChart"
import { ProjectTabs } from "@/components/islands/ProjectTabs"
import { SignalPanel } from "@/components/islands/SignalPanel"
import { QueryProvider } from "@/components/providers/QueryProvider"
import DashboardLayout from "@/layouts/DashboardLayout.astro"
import { apiFetch } from "@/lib/api"
import type { ProjectDetail } from "@/schemas/project"

const { id } = Astro.params

if (!id) {
	return new Response(null, { status: 404, statusText: "Not Found" })
}

let project: ProjectDetail | null = null
try {
	project = await apiFetch<ProjectDetail>(`/projects/${id}`)
} catch {
	return new Response(null, { status: 404, statusText: "Project not found" })
}

if (!project) {
	return new Response(null, { status: 404, statusText: "Project not found" })
}
---

<DashboardLayout title={`${project.name} — GeoStorm`}>
	{project.is_demo && <DemoBanner />}

	<div class="space-y-6 p-6">
		<div class="flex items-center justify-between">
			<div>
				<h1 class="text-2xl font-bold tracking-tight">{project.name}</h1>
				{project.description && (
					<p class="text-sm text-muted-foreground">{project.description}</p>
				)}
			</div>
			<QueryProvider client:load>
				<MonitorButton
					client:load
					projectId={id}
					isDemo={project.is_demo}
				/>
			</QueryProvider>
		</div>

		<QueryProvider client:load>
			<AlertsFeed projectId={id} />
			<div class="mt-6">
				<SignalPanel projectId={id} />
			</div>
			<div class="mt-6">
				<ProjectTabs projectId={id} isDemo={project.is_demo} />
			</div>
		</QueryProvider>

		<QueryProvider client:visible>
			<PerceptionChart projectId={id} />
		</QueryProvider>
	</div>
</DashboardLayout>
