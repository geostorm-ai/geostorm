# ============================================================
# GeoStorm Configuration
# ============================================================

# Required
SECRET_KEY=your-secret-key-change-in-production
OPENROUTER_API_KEY=sk-or-v1-...

# ============================================================
# Alert Delivery (configure at least one for observability value)
# ============================================================
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_FROM=
ALERT_EMAIL_RECIPIENTS=
WEBHOOK_URL=

# ============================================================
# Demo Mode
# ============================================================
# Set to true to run GeoStorm in read-only demo mode.
# In demo mode:
#   - All write operations return 403 (read-only)
#   - No authentication required for read endpoints
#   - Pre-seeded demo data is displayed
#   - A banner encourages visitors to self-host
DEMO_MODE=false

# ============================================================
# Telemetry (Transparent & Disable-able)
# ============================================================
# GeoStorm collects minimal anonymous usage telemetry to improve the project.
# Only metadata events are tracked (e.g. feature usage counts, durations).
# NEVER tracked: prompts, responses, API keys, competitor names, or business data.
# Set to false to completely disable all telemetry.
TELEMETRY_ENABLED=true
# PostHog API key for telemetry. When empty, telemetry is automatically disabled.
POSTHOG_API_KEY=

# ============================================================
# Optional Configuration
# ============================================================
WORKER_BATCH_SIZE=10
SCHEDULER_INTERVAL_MINUTES=5
